	<windowclass name="bettertools_cooking_contents">
		<margins control="0,0,0,2" />
		<script>
			function onInit()
				self.onLockModeChanged(WindowManager.getWindowReadOnlyState(self));
			end
			function onLockModeChanged(bReadOnly)
				WindowManager.callSafeControlsSetLockMode(self, { "list_iadd", "ingredient_idelete_header", }, bReadOnly);
				if bReadOnly then
					self.updateIngredientSortFields();
				end
			end
			function updateIngredientSortFields()
				for _, w in pairs(list.getWindows()) do
					if w.updateSortFields then
						w.updateSortFields();
					end
				end
			end
			function cookSelectedIngredients()
				BetterToolsCookingManager.cookSelectedIngredients(self);
			end
		</script>
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<label_charframetop name="ingredient_header">
				<anchored to="contentanchor" height="20">
					<top relation="relative" offset="2" />
					<left offset="10" />
					<right offset="-10" />
				</anchored>
				<icons>forge_item_advgear</icons>
				<static text="Bekannte Zutaten" />
			</label_charframetop>
			<button_iadd name="list_iadd">
				<anchored to="ingredient_header" position="insidetopright" offset="5,0" />
				<target>list</target>
			</button_iadd>
			<button_text name="cook_button">
				<anchored to="ingredient_header" position="insidetopleft" offset="5,0" width="70" height="20" />
				<state text="Kochen" />
				<script>
					function onButtonPress()
						window.cookSelectedIngredients();
					end
				</script>
			</button_text>

			<list_content_labeled_alternating_top name="list">
				<anchored height="420">
					<left offset="5" />
					<right offset="-5" />
				</anchored>
				<datasource>.ingredients</datasource>
				<class>bettertools_cooking_ingredient</class>
				<sortby>
					<control>sort_rarity</control>
					<control>sort_effectno</control>
					<control>sort_name</control>
				</sortby>
			</list_content_labeled_alternating_top>
			<scrollbar_list name="ingredient_scrollbar" />

			<anchor_list_content_label_left />
			<anchor_list_content_label_right />
			<spacer_list_content_idelete_label_left name="ingredient_idelete_header" />
			<spacer_list_content_button_checkbox_label_left name="spacer_use" />
			<label_list_content_number_left name="label_quantity">
